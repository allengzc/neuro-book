#!/usr/bin/env sh
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

# Walk up from SCRIPT_DIR to find the product root (.output directory)
PRODUCT_ROOT=""
probe="$SCRIPT_DIR"
while [ "$probe" != "/" ]; do
    if [ -d "$probe/.output" ]; then
        PRODUCT_ROOT="$probe"
        break
    fi
    probe=$(dirname "$probe")
done

# Fallback: try 5 levels up (original layout for Windows Product Portable)
if [ -z "$PRODUCT_ROOT" ]; then
    PRODUCT_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/../../../../.." && pwd)
fi

PRODUCT_VARIABLE_SCRIPT="$PRODUCT_ROOT/.output/server/scripts/build/variable.ts"
PORTABLE_BUN="$PRODUCT_ROOT/../runtime/bun/bun.exe"

if [ -f "$PRODUCT_VARIABLE_SCRIPT" ]; then
    if [ -f "$PORTABLE_BUN" ]; then
        exec "$PORTABLE_BUN" "$PRODUCT_VARIABLE_SCRIPT" "$@"
    fi
    exec "${BUN:-bun}" "$PRODUCT_VARIABLE_SCRIPT" "$@"
fi

exec "${BUN:-bun}" "$SCRIPT_DIR/../scripts/variable.ts" "$@"

#!/usr/bin/env sh
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
PRODUCT_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/../../../../.." && pwd)
PRODUCT_WORKSPACE_SCRIPT="$PRODUCT_ROOT/.output/server/scripts/agent/workspace.ts"
PORTABLE_BUN="$PRODUCT_ROOT/../runtime/bun/bun.exe"

if [ -f "$PRODUCT_WORKSPACE_SCRIPT" ]; then
    if [ -f "$PORTABLE_BUN" ]; then
        exec "$PORTABLE_BUN" "$PRODUCT_WORKSPACE_SCRIPT" "$@"
    fi
    exec "${BUN:-bun}" "$PRODUCT_WORKSPACE_SCRIPT" "$@"
fi

exec "${BUN:-bun}" "$SCRIPT_DIR/../scripts/workspace.ts" "$@"
